{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "python aspen_setup.py",
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5
  },
  "environment": {
    "FLASK_ENV": "production",
    "PORT": 5000
  }
}